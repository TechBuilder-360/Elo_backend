scalar Int64

input Registration {
  email_address: String!
  first_name: String!
  last_name: String!
  password: String!
}

type RegistrationResponse {
  user_id: String!
}

input Login {
  otp: String!
  identifier: String!
}

type LoginResponse {
  access_token: String!
  expire_at: Int64!
}

input RequestOTP {
  email_address: String!
  password: String!
}

type OTPResponse {
  Identifier: String!
}

type Mutation {
  registration(input: Registration!): RegistrationResponse!
  login(input: Login!): LoginResponse!
  requestOtp(input: RequestOTP): OTPResponse!
}
